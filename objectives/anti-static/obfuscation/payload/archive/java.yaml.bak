defaults:
  for: [binaries, data]
  platforms: [linux, macos, windows, unix, android, ios]
traits:
  - id: java-archive-slashed-class-folder
    desc: "ZIP entry with slash after class"
    crit: suspicious
    conf: 0.95
    if:
      type: raw
      # Matches a ZIP entry name ending in .class/
      # ZIP local file header filename starts at offset 30.
      # Central directory filename starts at offset 46.
      # We use a raw regex to find the pattern in the file.
      regex: '[\w/]+\.class/'
  - id: java-archive-class-folder-caesium
    desc: Slashed class folder with Caesium decoys
    crit: suspicious
    conf: 1.0
    count_min: 4
    if:
      type: raw
      regex: '\.class/caesium_\d+\.class'
