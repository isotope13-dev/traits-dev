defaults:
  for: [pe]
  platforms: [windows]
  size_min: 100000
  size_max: 16777216

composite_rules:
  - id: elex-accessbridge-wrapper-loader
    desc: Elex AccessBridge wrapper trojan
    crit: hostile
    conf: 0.99
    all:
      - id: objectives/command-and-control/dropper/execution/inject::accessbridge-wrapper-masquerade-cluster
    any:
      - id: objectives/evasion/process/injection/memory::process-inject-api
      - id: objectives/evasion/fileless/memory::remote-injection
      - id: objectives/privilege-escalation/process-injection::debug-privilege-injection
      - id: objectives/anti-static/pack/polymorphic::xor-jmp-short-loop
    unless:
      - id: metadata/signed/platform::microsoft
