defaults:
  platforms: [linux, macos, windows, unix, android, ios]
  for: [jar]
  attack: "T1195.002"

traits:
  - id: processor-service-descriptor
    desc: JAR annotation processor service descriptor
    crit: notable
    conf: 0.99
    if:
      type: raw
      exact: META-INF/services/javax.annotation.processing.Processor

  - id: processor-implementation
    desc: Annotation processor implementation class
    crit: notable
    conf: 0.97
    if:
      type: raw
      exact: tools/base/debug/model/annotation/DebugBuildConfigProcessor

  - id: abstract-processor-api
    desc: Java annotation processor API
    crit: notable
    conf: 0.94
    if:
      type: raw
      substr: javax/annotation/processing/AbstractProcessor

  - id: init-trigger
    desc: Annotation processor build trigger
    crit: suspicious
    conf: 0.96
    if:
      type: raw
      exact: annotation-processor

  - id: static-init-trigger
    desc: Static initializer build trigger
    crit: suspicious
    conf: 0.94
    if:
      type: raw
      exact: static-init

  - id: callback-class
    desc: Build callback helper class
    crit: suspicious
    conf: 0.92
    if:
      type: raw
      exact: tools/base/debug/model/BuildSystemCallback

  - id: daemon-build-thread
    desc: Daemonized build diagnostics thread
    crit: suspicious
    conf: 0.95
    if:
      type: raw
      exact: build-diag

  - id: single-thread-executor
    desc: Single-thread executor for callback
    crit: component
    conf: 0.88
    if:
      type: raw
      exact: newSingleThreadExecutor

  - id: url-encoding-query
    desc: Callback query parameter encoding
    crit: component
    conf: 0.89
    if:
      type: raw
      exact: java/net/URLEncoder

  - id: callback-query-shape
    desc: Build telemetry callback query shape
    crit: suspicious
    conf: 0.97
    if:
      type: raw
      exact: ?status=200&trigger=

  - id: callback-query-source
    desc: Build telemetry source parameter
    crit: component
    conf: 0.94
    if:
      type: raw
      exact: "&src="

  - id: callback-query-package
    desc: Hardcoded package callback identifier
    crit: suspicious
    conf: 0.98
    if:
      type: raw
      exact: "&pkg=tools.base.build-system.debug:model"

  - id: pipedream-oob-subdomain
    desc: Pipedream OOB subdomain pattern
    crit: notable
    conf: 0.95
    if:
      type: raw
      regex: eoa[0-9]+[a-z]+[0-9]+\.m\.pipedream\.net

  - id: google-masquerade-uberproxy
    desc: Google-themed callback health endpoint (masquerade)
    crit: suspicious
    conf: 0.97
    if:
      type: raw
      exact: https://uberproxy.corp.google.com/procz

  - id: google-masquerade-pack-status
    desc: Google-themed pack status endpoint (masquerade)
    crit: suspicious
    conf: 0.97
    if:
      type: raw
      exact: https://r2---sn-5goenes.c.pack.google.com/statusz

  - id: google-masquerade-sandbox-endpoint
    desc: Google-themed sandbox callback endpoint (masquerade)
    crit: suspicious
    conf: 0.97
    if:
      type: raw
      exact: https://test-scone-pa-googleapis.sandbox.google.com

  - id: annotation-processor-service-descriptor
    desc: JAR bundles auto-loaded annotation processor service descriptor
    crit: notable
    conf: 0.995
    if:
      type: raw
      exact: META-INF/services/javax.annotation.processing.Processor

  - id: annotation-processor-impl-class
    desc: JAR bundles annotation processor implementation class
    crit: notable
    conf: 0.99
    if:
      type: raw
      exact: tools/base/debug/model/annotation/DebugBuildConfigProcessor

  - id: annotation-processor-abstract-api
    desc: Java annotation processor AbstractProcessor API
    crit: notable
    conf: 0.97
    if:
      type: raw
      exact: javax/annotation/processing/AbstractProcessor

  - id: build-pingback-archive-yara
    desc: JAR embeds build callback pingback flow
    crit: suspicious
    conf: 0.995
    if:
      type: yara
      source: |
        rule java_build_pingback_archive {
          strings:
            $callback = "tools/base/debug/model/BuildSystemCallback" ascii
            $thread = "build-diag" ascii
            $http = "java/net/HttpURLConnection" ascii
            $query = "?status=200&trigger=" ascii
            $pkg = "&pkg=tools.base.build-system.debug:model" ascii
            $pipe = "pipedream.net" ascii
          condition:
            filesize < 100KB and all of them
        }

  - id: google-masquerade-archive-yara
    desc: JAR embeds faux Google callback hosts
    crit: suspicious
    conf: 0.99
    if:
      type: yara
      source: |
        rule java_google_masquerade_archive {
          strings:
            $a = "https://uberproxy.corp.google.com/procz" ascii
            $b = "https://r2---sn-5goenes.c.pack.google.com/statusz" ascii
            $c = "https://test-scone-pa-googleapis.sandbox.google.com" ascii
          condition:
            2 of them
        }

  - id: annotation-processor-class-yara
    desc: Java class implements annotation processor callback
    crit: suspicious
    conf: 0.995
    for: [class]
    if:
      type: yara
      source: |
        rule java_annotation_processor_class {
          strings:
            $api = "javax/annotation/processing/AbstractProcessor" ascii
            $trigger = "annotation-processor" ascii
            $supported = "SupportedAnnotationTypes" ascii
            $callback = "tools/base/debug/model/BuildSystemCallback" ascii
          condition:
            filesize < 16KB and all of them
        }

  - id: build-callback-class
    desc: Java class performs build callback HTTP flow
    crit: suspicious
    conf: 0.99
    for: [class]
    if:
      type: raw
      substr: tools/base/debug/model/BuildSystemCallback
    -
      id: build-callback-thread-name
      desc: Build callback thread name
      crit: suspicious
      conf: 0.98
      for: [class]
      if:
        type: raw
        exact: build-diag
    -
      id: build-callback-http流
      desc: HTTP connection in callback class
      crit: suspicious
      conf: 0.96
      for: [class]
      if:
        type: raw
        exact: java/net/HttpURLConnection

  - id: build-callback-google-class-yara
    desc: Java callback class mimics Google endpoints
    crit: suspicious
    conf: 0.99
    for: [class]
    if:
      type: yara
      source: |
        rule java_build_callback_google_class {
          strings:
            $a = "https://uberproxy.corp.google.com/procz" ascii
            $b = "https://r2---sn-5goenes.c.pack.google.com/statusz" ascii
            $c = "https://test-scone-pa-googleapis.sandbox.google.com" ascii
          condition:
            filesize < 16KB and 2 of them
        }

  - id: static-init-callback-class-yara
    desc: Java class triggers callback from static init
    crit: suspicious
    conf: 0.98
    for: [class]
    if:
      type: yara
      source: |
        rule java_static_init_callback_class {
          strings:
            $trigger = "static-init" ascii
            $callback = "tools/base/debug/model/BuildSystemCallback" ascii
            $report = "report" ascii
          condition:
            filesize < 16KB and all of them
        }

composite_rules:
  - id: auto-loaded-annotation-processor
    desc: Build annotation processor trigger path
    crit: suspicious
    conf: 0.99
    any:
      - id: annotation-processor-class-yara
      - id: annotation-processor-archive-yara

  - id: build-callback-thread
    desc: Background callback thread during build
    crit: suspicious
    conf: 0.96
    all:
      - id: single-thread-executor
    any:
      - id: build-callback-class-yara
      - id: build-pingback-archive-yara

  - id: build-callback-masquerade
    desc: Build callback masquerades as Google infrastructure
    crit: suspicious
    conf: 0.98
    any:
      - id: build-callback-google-class-yara
      - id: google-corp-procz
      - id: google-pack-statusz
      - id: google-sandbox-endpoint
      - id: google-masquerade-archive-yara

  - id: build-oob-pingback
    desc: Build-time annotation processor pingback to OOB endpoint
    crit: hostile
    conf: 0.995
    attack: T1041
    all:
      - id: build-callback-class-yara
      - id: build-callback-google-class-yara
      - id: callback-query-source
      - id: url-encoding-query
      - id: micro-behaviors/communications/http/lib/urlconnection::request-java-bytecode

  - id: build-static-init-pingback
    desc: Static initializer triggers build-time pingback
    crit: suspicious
    conf: 0.993
    attack: T1041
    any:
      - id: static-init-callback-class-yara
      - id: static-init-trigger
