# HTTP C2 Protocol Detection - Composites
# Detects suspicious HTTP patterns that may indicate C2 communication
# ATT&CK: T1071.001 (Application Layer Protocol: Web Protocols)
defaults:
  for: [elf, pe, macho]
  attack: "T1071.001"
  crit: suspicious
traits:
  - id: http-method-get
    desc: Hardcoded GET method string
    crit: component
    conf: 0.6
    if:
      type: string
      substr: "GET /"
  - id: http-method-post
    desc: Hardcoded POST method string
    crit: notable
    conf: 0.65
    if:
      type: string
      substr: "POST /"
  - id: http-delimiter
    desc: HTTP header delimiter (CRLF CRLF)
    # Component: CRLF CRLF is common in any binary; only meaningful in composites
    crit: component
    conf: 0.5
    if:
      type: raw
      regex: '\r\n\r\n'
  # Removed http-user-agent duplicate - use micro-behaviors/communications/http/request::user-agent-header
  - id: http-content-type
    desc: Content-Type header string
    crit: notable
    conf: 0.5
    if:
      type: string
      substr: "Content-Type:"
  - id: http-request-line
    desc: HTTP request-line literal
    crit: notable
    conf: 0.7
    if:
      type: raw
      regex: '(GET|POST)\s+/[^\r\n]{0,200}\s+HTTP/1\.[01]'
  - id: http-beacon-counter
    desc: HTTP request with counter/sequence parameter
    crit: suspicious
    conf: 0.88
    if:
      type: string
      # Format string for parameterized HTTP beacon (e.g., "POST %s?r=%d HTTP/1.1")
      # The ?r= query parameter encodes a request counter/sequence number
      regex: '(GET|POST) %s\?[a-z]{1,4}=%d HTTP/1\.'
composite_rules:
  - id: http-protocol
    desc: HTTP or HTTPS protocol marker
    crit: notable
    conf: 0.6
    any:
      - id: micro-behaviors/communications/http/protocol::http-prefix
      - id: micro-behaviors/communications/http/protocol::https-prefix
  - id: hardcoded-request
    desc: "Hardcoded HTTP request in binary"
    crit: suspicious
    conf: 0.7
    all:
      - id: http-protocol
    any:
      - id: http-request-line
      - id: http-method-get
    downgrade:
      any:
        - id: micro-behaviors/communications/ip/resolve::resolve-getaddrinfo
        - id: micro-behaviors/communications/dns/lookup/reverse::in-addr-arpa
  - id: custom-client
    desc: "Custom HTTP client implementation"
    crit: suspicious
    conf: 0.65
    all:
      - id: http-protocol
      - id: http-delimiter
    any:
      - id: micro-behaviors/communications/http/request::user-agent-header
      - id: http-content-type
    unless:
      - type: string
        substr: "application/ocsp-request"
    downgrade:
      any:
        - id: micro-behaviors/communications/ip/resolve::resolve-getaddrinfo
        - id: micro-behaviors/communications/dns/lookup/reverse::in-addr-arpa
        - id: micro-behaviors/dylib/library::libcurl-ref
