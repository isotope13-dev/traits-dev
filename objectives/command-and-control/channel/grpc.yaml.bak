# gRPC-based C2 Channel Detection
# Detects use of gRPC (Google Remote Procedure Call) for command and control.
# gRPC is rarely used in legitimate compiled binaries directly for C2, but is
# used by several Go-based malware families including JaskaGO, Sliver, and custom RATs.
# ATT&CK: T1071.001 (C2: Application Layer Protocol: Web Protocols)
defaults:
  platforms:
    - linux
    - macos
    - windows
  for:
    - macho
    - elf
    - pe
  attack: T1071.001
  crit: notable

traits:
  - id: grpc-go-import
    desc: google.golang.org/grpc import in binary
    conf: 0.8
    if:
      type: string_value
      substr: google.golang.org/grpc

  - id: grpc-process-responses-stream
    desc: gRPC bidirectional ProcessResponses stream (C2 command channel)
    crit: suspicious
    conf: 0.9
    if:
      type: string_value
      substr: ProcessResponsesServer

  - id: grpc-command-processor
    desc: gRPC CommandProcessor service (remote command dispatch)
    crit: suspicious
    conf: 0.9
    if:
      type: string_value
      regex: proto\.CommandProcessor(Client|Server)

  - id: grpc-go-user-agent
    desc: grpc-go user agent in binary (hardcoded gRPC version string)
    conf: 0.75
    if:
      type: string_value
      regex: grpc-go/\d+\.\d+

  - id: grpc-proto-main
    desc: Leaked proto/main.proto build artifact path
    crit: suspicious
    conf: 0.85
    if:
      type: string_value
      regex: proto/main\.(proto|pb\.go)

composite_rules:
  - id: grpc-c2-channel
    desc: gRPC-based C2 channel (bidirectional command stream)
    crit: suspicious
    conf: 0.9
    attack: T1071.001
    all:
      - id: grpc-go-import
    any:
      - id: grpc-process-responses-stream
      - id: grpc-command-processor

  - id: grpc-c2-with-proto
    desc: gRPC C2 with compiled protobuf and command dispatch
    crit: suspicious
    conf: 0.95
    attack: T1071.001
    all:
      - id: grpc-go-import
      - id: grpc-proto-main
    any:
      - id: grpc-process-responses-stream
      - id: grpc-command-processor
