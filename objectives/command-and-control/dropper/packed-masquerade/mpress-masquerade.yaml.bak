# MPRESS-packed PE droppers that masquerade as legitimate installers
# and contain hardcoded C2 endpoints in their resource sections.
# Common pattern: Virus.Infector.ATA and similar infector/dropper families.
defaults:
  platforms: [windows]
  for: [pe]
  attack: T1105
  mbc: B0023

composite_rules:
  - id: mpress-masquerade-c2-dropper
    desc: MPRESS-packed masquerading PE with C2 endpoint
    crit: hostile
    conf: 0.96
    all:
      - id: objectives/anti-static/pack/mpress::mpress-two-section-loader
      - id: micro-behaviors/communications/ip/endpoint::external-ipv4-port-rsrc-single
    any:
      - id: objectives/evasion/masquerade/brand/installer::adobe-bootstrapper-masquerade
      - id: objectives/evasion/masquerade/version-resource/contradiction::adobe-bootstrapper-versioninfo
    unless:
      - id: metadata/signed/platform::microsoft
      - id: metadata/signed/platform::adobe
      - id: metadata/signed/developer::adobe-systems
