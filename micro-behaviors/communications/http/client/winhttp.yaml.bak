defaults:
  for: [pe, dll]
  platforms: [windows]
  attack: "T1071.001"
  mbc: "C0002"
traits:
  - id: winhttp-open
    desc: Initialize WinHTTP session
    crit: notable
    conf: 0.9
    if:
      type: symbol
      exact: "WinHttpOpen"
  - id: winhttp-connect
    desc: Connect WinHTTP to remote host
    crit: notable
    conf: 0.9
    if:
      type: symbol
      exact: "WinHttpConnect"
  - id: winhttp-open-request
    desc: Create WinHTTP HTTP request handle
    crit: notable
    conf: 0.9
    if:
      type: symbol
      exact: "WinHttpOpenRequest"
  - id: winhttp-set-timeouts
    desc: Configure WinHTTP request timeouts
    crit: notable
    conf: 0.85
    if:
      type: symbol
      exact: "WinHttpSetTimeouts"
  - id: winhttp-send-request
    desc: Send WinHTTP request to server
    crit: notable
    conf: 0.9
    if:
      type: symbol
      exact: "WinHttpSendRequest"
  - id: winhttp-receive-response
    desc: Receive WinHTTP server response
    crit: notable
    conf: 0.9
    if:
      type: symbol
      exact: "WinHttpReceiveResponse"
  - id: winhttp-read-data
    desc: Read WinHTTP response body
    crit: notable
    conf: 0.85
    if:
      type: symbol
      exact: "WinHttpReadData"
  - id: winhttp-query-data-available
    desc: Query WinHTTP buffered response bytes
    crit: notable
    conf: 0.85
    if:
      type: symbol
      exact: "WinHttpQueryDataAvailable"
  - id: winhttp-query-headers
    desc: Query WinHTTP response headers
    crit: notable
    conf: 0.88
    if:
      type: symbol
      exact: "WinHttpQueryHeaders"
  - id: winhttp-close-handle
    desc: Close WinHTTP handle object
    crit: baseline
    conf: 0.8
    if:
      type: symbol
      exact: "WinHttpCloseHandle"
  - id: winhttp-open-string
    desc: WinHTTP Open API name string
    crit: notable
    conf: 0.8
    if:
      type: string
      exact: "WinHttpOpen"
  - id: winhttp-connect-string
    desc: WinHTTP Connect API name string
    crit: notable
    conf: 0.8
    if:
      type: string
      exact: "WinHttpConnect"
  - id: winhttp-close-handle-string
    desc: WinHTTP CloseHandle API name string
    crit: baseline
    conf: 0.75
    if:
      type: string
      exact: "WinHttpCloseHandle"
  - id: winhttp-open-request-string
    desc: WinHTTP OpenRequest API name string
    crit: notable
    conf: 0.84
    if:
      type: string
      exact: "WinHttpOpenRequest"
  - id: winhttp-set-timeouts-string
    desc: WinHTTP SetTimeouts API name string
    crit: notable
    conf: 0.8
    if:
      type: string
      exact: "WinHttpSetTimeouts"
  - id: winhttp-send-request-string
    desc: WinHTTP SendRequest API name string
    crit: notable
    conf: 0.84
    if:
      type: string
      exact: "WinHttpSendRequest"
  - id: winhttp-receive-response-string
    desc: WinHTTP ReceiveResponse API name string
    crit: notable
    conf: 0.84
    if:
      type: string
      exact: "WinHttpReceiveResponse"
  - id: winhttp-read-data-string
    desc: WinHTTP ReadData API name string
    crit: notable
    conf: 0.82
    if:
      type: string
      exact: "WinHttpReadData"
  - id: winhttp-query-data-available-string
    desc: WinHTTP QueryDataAvailable API name string
    crit: notable
    conf: 0.82
    if:
      type: string
      exact: "WinHttpQueryDataAvailable"
  - id: winhttp-query-headers-string
    desc: WinHTTP QueryHeaders API name string
    crit: notable
    conf: 0.82
    if:
      type: string
      exact: "WinHttpQueryHeaders"
composite_rules:
  - id: winhttp-request-flow
    desc: WinHTTP request response data flow
    crit: notable
    conf: 0.9
    all:
      - id: winhttp-open-request
      - id: winhttp-set-timeouts
      - id: winhttp-send-request
      - id: winhttp-receive-response
    any:
      - id: winhttp-read-data
      - id: winhttp-query-data-available
      - id: winhttp-query-headers
  - id: winhttp-request-flow-string-fallback
    desc: WinHTTP request flow from API strings
    crit: notable
    conf: 0.84
    all:
      - id: winhttp-open-request-string
      - id: winhttp-set-timeouts-string
      - id: winhttp-send-request-string
      - id: winhttp-receive-response-string
    any:
      - id: winhttp-read-data-string
      - id: winhttp-query-data-available-string
      - id: winhttp-query-headers-string
  - id: winhttp-session-flow-string-fallback
    desc: WinHTTP session setup API strings
    crit: notable
    conf: 0.8
    all:
      - id: winhttp-open-string
      - id: winhttp-connect-string
    any:
      - id: winhttp-close-handle-string
      - id: winhttp-close-handle
  - id: winhttp-request-flow
    desc: WinHTTP request response data flow
    crit: notable
    conf: 0.9
    all:
      - id: winhttp-request-flow-string-fallback
    any:
      - id: winhttp-request-flow
      - id: winhttp-session-flow-string-fallback
