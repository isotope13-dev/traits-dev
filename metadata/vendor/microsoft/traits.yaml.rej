@@ -2,6 +2,18 @@
   platforms: [windows]
   for: [pe, dll]
 traits:
+  - id: microsoft-corp-versioninfo
+    desc: Claims Microsoft Corp in version resource
+    crit: component
+    conf: 0.9
+    if:
+      type: string
+      regex: "Microsoft Corp(oration)?\\.?"
+      case_insensitive: true
+      section: .rsrc
+    downgrade:
+      any:
+        - id: metadata/quality/versioning::pe-version-resource
   - id: microsoft-corp-marker
     desc: Embedded Microsoft vendor marker
     crit: baseline
